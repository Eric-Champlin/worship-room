# Worship Room — backend environment variables
# ────────────────────────────────────────────────────────────────────────────
# Copy this file to backend/.env.local and fill in real values. .env.local is
# gitignored. Never commit real keys.
#
# ONBOARDING STEP: before running `docker compose up backend` for the
# first time, copy this file to .env.local in this same directory:
#
#     cp backend/.env.example backend/.env.local
#
# Then fill in real key values. Without .env.local the backend will still
# start (as of docker-compose v2.24+ the env_file is marked optional), but
# /api/v1/health will report all providers as unconfigured.
#
# In production, your hosting platform (Railway/Render) injects env vars
# directly — do NOT deploy a .env.local file to production.
# ────────────────────────────────────────────────────────────────────────────

# ─── Active profile ────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ─── Gemini (used by Spec 2) ───────────────────────────────────────────────
# Same value as VITE_GEMINI_API_KEY in frontend/.env.local.
# After Spec 2 ships, this becomes the SOLE source of truth for the Gemini
# key — VITE_GEMINI_API_KEY can be removed from the frontend .env.local.
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Google Maps (used by Spec 3) ──────────────────────────────────────────
# Same value as VITE_GOOGLE_MAPS_API_KEY in frontend/.env.local.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# ─── FCBH (used by Spec 4) ─────────────────────────────────────────────────
# Same value as VITE_FCBH_API_KEY in frontend/.env.local.
FCBH_API_KEY=your-fcbh-api-key-here

# ─── Redis (used by Spec 5.6 — cache + rate limiter) ───────────────────────
# Connection precedence: REDIS_URL wins if set, else triplet.
#
# REDIS_URL format (Upstash-compatible): redis[s]://[user][:password]@host[:port][/db]
# Examples:
#   Upstash:               rediss://default:<password>@<region>.upstash.io:6379
#   Local docker-compose:  redis://localhost:6380  (or leave REDIS_URL empty and use the triplet)
#
# In dev, the docker-compose redis service is reachable at localhost:6380 with no
# password — host port 6380 maps to container port 6379 to coexist with sibling
# projects' Redis instances on the same workstation. See
# backend/docs/redis-conventions.md § "Dev port" for the rationale.
# In prod, set REDIS_URL via Railway/Upstash UI; do NOT commit real values.
#
# Redis is OPTIONAL in production (Spec 5.6 D4). If unreachable, backend boots with
# in-memory cache + in-memory rate limiter; /actuator/health reports DEGRADED.
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# ─── Object Storage (Spec 1.10e + downstream consumers) ────────────────────
# In dev profile, the LocalFilesystem adapter is used and STORAGE_* are not read.
# In test profile, MinIO Testcontainer injects values via @DynamicPropertySource.
# In prod profile, ALL of STORAGE_BUCKET / STORAGE_REGION / STORAGE_ACCESS_KEY /
# STORAGE_SECRET_KEY / STORAGE_ENDPOINT_URL must be set or boot fails fast (see
# S3StorageAdapter @PostConstruct + backend/docs/runbook-storage.md).
#
# Worship Room production uses Cloudflare R2 (S3-API-compatible).
# R2 endpoint format: https://<account-id>.r2.cloudflarestorage.com
# R2 region is conventionally "auto".
STORAGE_BUCKET=worshiproom-prod
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=your-r2-access-key-id-here
STORAGE_SECRET_KEY=your-r2-secret-access-key-here
STORAGE_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
STORAGE_MAX_PRESIGN_HOURS=1
