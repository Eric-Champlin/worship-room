# ---------------------------------------------------------------------------
# Worship Room — frontend environment variables
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored (see repo-root .gitignore: `.env.local`, `*.local`). Never commit
# real keys.
#
# All variables are read via `frontend/src/lib/env.ts` where a centralized
# module exposes typed, require-on-use accessors. Inline `import.meta.env.*`
# reads elsewhere in the codebase are legacy and should migrate to env.ts
# when touched.
# ---------------------------------------------------------------------------

# Core app configuration
VITE_API_BASE_URL=http://localhost:8080
VITE_SITE_URL=https://worshiproom.com
VITE_HERO_VIDEO_URL=https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260308_114720_3dabeb9e-2c39-4907-b747-bc3544e2d5b7.mp4

# ---------------------------------------------------------------------------
# AI / third-party API keys
# ---------------------------------------------------------------------------
# Keys are OPTIONAL at module load (so missing keys don't break the app for
# features that don't use them) and REQUIRED at feature use time via the
# `require*` helpers in `src/lib/env.ts`. Features that depend on a missing
# key will fail loudly with a clear error; everything else is unaffected.

# Google Gemini API key (for AI-powered features: BB-30 Explain This Passage, etc.)
# Obtain from: Google Cloud Console → APIs & Services → Credentials
# Restrict to: Gemini API only, with HTTP referrer restrictions for localhost and production domain
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# Google Maps Platform API key (for future Local Support feature: churches, counselors, Celebrate Recovery)
# Obtain from: Google Cloud Console → APIs & Services → Credentials
# Restrict to: Maps JavaScript API, Places API (New), Geocoding API, with HTTP referrer restrictions
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Web Push Notifications — VAPID key (BB-41)
# The VAPID public key is used to authenticate push subscription requests.
# For local dev, use this placeholder. Push subscriptions will be created
# but notifications won't arrive without a matching private key on the server.
# The real key pair is generated and managed by the Phase 3 backend.
# Generate a real key pair: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=BEl62iUYgUivxIkv69yViEuiBIa-Ib9-SkvMeAtA3LFgDzkOs-dRgkJiVWFCL_F-rxJGXPbUZMR0a0xS9mW_Y78

# ---------------------------------------------------------------------------
# FCBH Digital Bible Platform v4 API key (for BB-26: Audio Bible)
# ---------------------------------------------------------------------------
# Obtain from: https://www.faithcomesbyhearing.com/bible-brain/dbp-api
# Used by: BibleReader audio playback for WEB Bible narration via DBP v4.
# Absence of the key disables the audio button across all chapters (silent
# fallback; no user-visible error).
VITE_FCBH_API_KEY=your-fcbh-api-key-here
