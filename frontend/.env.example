# ---------------------------------------------------------------------------
# Worship Room — frontend environment variables
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored (see repo-root .gitignore: `.env.local`, `*.local`). Never commit
# real keys.
#
# All variables are read via `frontend/src/lib/env.ts` where a centralized
# module exposes typed, require-on-use accessors. Inline `import.meta.env.*`
# reads elsewhere in the codebase are legacy and should migrate to env.ts
# when touched.
# ---------------------------------------------------------------------------

# Core app configuration
VITE_API_BASE_URL=http://localhost:8080
VITE_SITE_URL=https://worshiproom.com
VITE_HERO_VIDEO_URL=https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260308_114720_3dabeb9e-2c39-4907-b747-bc3544e2d5b7.mp4

# ---------------------------------------------------------------------------
# Phase 3 Forums Wave — backend migration flags
# ---------------------------------------------------------------------------
# Dual-write feature flags for migrating frontend features to the backend.
# Default `true` means the dual-write to the backend fires alongside the
# existing localStorage write. Reads remain localStorage-canonical until a
# future "promote backend reads" spec flips that piece. New cutover flags
# in subsequent phases follow the same activation pattern.

# Activity dual-write: POST /api/v1/activity after each localStorage activity write.
# Activated by Spec 2.9 cutover on 2026-04-27.
VITE_USE_BACKEND_ACTIVITY=true

# Friends dual-write: POST/PATCH/DELETE on friend mutation endpoints after each
# localStorage friends write. Activated by Spec 2.5.5 cutover on 2026-04-27.
VITE_USE_BACKEND_FRIENDS=true

# Spec 2.5.4b — dual-write social interactions (encouragements, nudges, recap
# dismissal) to the backend. Activated by Spec 2.5.5 cutover on 2026-04-27.
VITE_USE_BACKEND_SOCIAL=true

# Spec 2.5.7 — dual-write mute mutations (mute / unmute) to the backend
# alongside the existing localStorage write to wr_mutes. Default `false` so
# Spec 2.5.7 ships without immediate backend traffic; flip to `true` after
# a smoke test (mute → backend row appears via psql; unmute → row deleted).
VITE_USE_BACKEND_MUTES=false

# Phase 3 Prayer Wall read-swap. When 'true', /prayer-wall, /prayer-wall/:id,
# /prayer-wall/user/:id, /prayer-wall/dashboard read from the backend instead
# of in-memory mocks. Default false until Spec 3.12 cutover. NOTE: read-swap,
# not dual-write — localStorage is NOT written when this flag is on.
VITE_USE_BACKEND_PRAYER_WALL=false

# ---------------------------------------------------------------------------
# AI / third-party API keys
# ---------------------------------------------------------------------------
# Keys are OPTIONAL at module load (so missing keys don't break the app for
# features that don't use them) and REQUIRED at feature use time via the
# `require*` helpers in `src/lib/env.ts`. Features that depend on a missing
# key will fail loudly with a clear error; everything else is unaffected.

# Google Maps: the VITE_GOOGLE_MAPS_API_KEY was decommissioned in Spec 3
# (ai-proxy-maps). The Maps API key now lives only on the backend as
# GOOGLE_MAPS_API_KEY — see backend/.env.example and backend/.env.local.
# All Maps calls (Places text search, Geocoding, photo media) route through
# /api/v1/proxy/maps/*. Do not reintroduce a frontend Maps key.

# Web Push Notifications — VAPID key (BB-41)
# The VAPID public key is used to authenticate push subscription requests.
# For local dev, use this placeholder. Push subscriptions will be created
# but notifications won't arrive without a matching private key on the server.
# The real key pair is generated and managed by the Phase 3 backend.
# Generate a real key pair: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=BEl62iUYgUivxIkv69yViEuiBIa-Ib9-SkvMeAtA3LFgDzkOs-dRgkJiVWFCL_F-rxJGXPbUZMR0a0xS9mW_Y78

# FCBH: the VITE_FCBH_API_KEY was decommissioned in Spec 4 (ai-proxy-fcbh).
# The FCBH API key now lives only on the backend as FCBH_API_KEY — see
# backend/.env.example and backend/.env.local. All DBP calls (bibles list,
# filesets, chapter audio URLs, timestamps) route through /api/v1/proxy/bible/*.
# Do not reintroduce a frontend FCBH key. The backend reports readiness via
# /api/v1/health.providers.fcbh.configured, consumed by fcbh-readiness.ts.
